generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  restaurant
  rider
  admin
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  picked_up
  delivered
  cancelled
}

enum DeliveryMode {
  platform
  self
  pickup
}

enum VoucherType {
  percentage
  flat
}

enum PayoutStatus {
  pending
  processing
  paid
  failed
}

enum LoyaltyPointType {
  earned
  redeemed
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole @default(customer)
  roles        String[] @default(["customer"])   // all granted roles
  phone        String?
  avatar       String?
  googleId     String?  @unique
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  fcmToken     String?
  // email verification
  emailVerifyToken   String?
  emailVerifyExpiry  DateTime?
  // password reset
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses       Address[]
  ownedRestaurant Restaurant?    @relation("RestaurantOwner")
  orders          Order[]        @relation("CustomerOrders")
  deliveries      Order[]        @relation("RiderDeliveries")
  ratings         Rating[]       @relation("RaterRatings")
  receivedRatings Rating[]       @relation("TargetRatings")
  notifications   Notification[]
  chatMessages    ChatMessage[]
  riderEarnings   RiderEarning[]
  payouts         Payout[]
  loyaltyPoints   LoyaltyPoint[]
  rider           Rider?
  refreshTokens   RefreshToken[]
  restaurantApplications RestaurantApplication[]
  riderApplications      RiderApplication[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique   // SHA-256 of the raw token
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum ApplicationStatus {
  pending
  approved
  rejected
  more_info_required
}

enum VehicleType {
  bike
  bicycle
  car
}

model RestaurantApplication {
  id              String            @id @default(cuid())
  userId          String
  // Basic info
  restaurantName  String
  description     String            @db.Text
  cuisineTypes    String[]
  address         String
  city            String
  phone           String
  // Owner details
  ownerName       String
  ownerCnic       String
  bankAccountName String
  bankAccountNo   String
  bankName        String
  // Files
  logoUrl         String?
  bannerUrl       String?
  documents       String[]
  // Review
  status          ApplicationStatus @default(pending)
  adminNote       String?           @db.Text
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("restaurant_applications")
}

model RiderApplication {
  id          String            @id @default(cuid())
  userId      String
  fullName    String
  cnic        String
  phone       String
  vehicleType VehicleType
  vehicleNo   String
  licenseNo   String
  city        String
  documents   String[]
  status      ApplicationStatus @default(pending)
  adminNote   String?           @db.Text
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("rider_applications")
}

model Address {
  id          String  @id @default(cuid())
  userId      String
  label       String
  lat         Float
  lng         Float
  fullAddress String
  isDefault   Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Restaurant {
  id             String       @id @default(cuid())
  ownerId        String       @unique
  name           String
  description    String       @db.Text
  phone          String?
  logo           String?
  banner         String?
  cuisineTypes   String[]
  isOpen         Boolean      @default(false)
  deliveryMode   DeliveryMode @default(platform)
  minOrder       Float        @default(10.0)
  prepTime       Int          @default(30)
  commissionRate Float        @default(0.15)
  deliveryFee    Float        @default(2.99)
  rating         Float        @default(0)
  totalRatings   Int          @default(0)
  address        String
  lat            Float
  lng            Float
  isApproved     Boolean      @default(false)
  isSuspended    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  owner           User               @relation("RestaurantOwner", fields: [ownerId], references: [id])
  menuCategories  MenuCategory[]
  menuItems       MenuItem[]
  orders          Order[]
  promotions      Promotion[]
  operatingHours  OperatingHours[]

  @@map("restaurants")
}

model OperatingHours {
  id           String @id @default(cuid())
  restaurantId String
  day          Int    // 0 = Sunday, 6 = Saturday
  open         String // HH:MM
  close        String // HH:MM
  isClosed     Boolean @default(false)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, day])
  @@map("operating_hours")
}

model MenuCategory {
  id           String @id @default(cuid())
  restaurantId String
  name         String
  sortOrder    Int    @default(0)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id           String   @id @default(cuid())
  restaurantId String
  categoryId   String
  name         String
  description  String   @db.Text
  photo        String?
  price        Float
  isAvailable  Boolean  @default(true)
  dietaryTags  String[]
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category       MenuCategory    @relation(fields: [categoryId], references: [id])
  modifierGroups ModifierGroup[]
  orderItems     OrderItem[]

  @@map("menu_items")
}

model ModifierGroup {
  id         String @id @default(cuid())
  menuItemId String
  name       String
  minSelect  Int    @default(0)
  maxSelect  Int    @default(1)

  menuItem MenuItem          @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options  ModifierOption[]

  @@map("modifier_groups")
}

model ModifierOption {
  id        String @id @default(cuid())
  groupId   String
  name      String
  extraCost Float  @default(0)

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("modifier_options")
}

model Order {
  id              String      @id @default(cuid())
  customerId      String
  restaurantId    String
  riderId         String?
  addressId       String
  status          OrderStatus @default(pending)
  subtotal        Float
  deliveryFee     Float
  discount        Float       @default(0)
  total           Float
  scheduledFor    DateTime?
  voucherCode     String?
  paymentMethod   String      @default("cash")
  paymentIntentId String?
  isPaid          Boolean     @default(false)
  customerNote    String?     @db.Text
  estimatedDelivery DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer  User       @relation("CustomerOrders", fields: [customerId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  rider     User?      @relation("RiderDeliveries", fields: [riderId], references: [id])
  address   Address    @relation(fields: [addressId], references: [id])

  items         OrderItem[]
  delivery      Delivery?
  ratings       Rating[]
  chatMessages  ChatMessage[]
  riderEarning  RiderEarning?
  loyaltyPoints LoyaltyPoint[]

  @@map("orders")
}

model OrderItem {
  id                 String @id @default(cuid())
  orderId            String
  menuItemId         String
  name               String
  photo              String?
  quantity           Int
  price              Float
  customisations     Json   @default("[]")
  specialInstructions String? @db.Text

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model Voucher {
  id           String      @id @default(cuid())
  code         String      @unique
  type         VoucherType
  value        Float
  minOrder     Float       @default(0)
  validFrom    DateTime
  validTo      DateTime
  usageLimit   Int         @default(100)
  usedCount    Int         @default(0)
  restaurantId String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())

  @@map("vouchers")
}

model Delivery {
  id           String    @id @default(cuid())
  orderId      String    @unique
  riderId      String
  pickedUpAt   DateTime?
  deliveredAt  DateTime?
  proofPhoto   String?
  createdAt    DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])
  rider Rider @relation(fields: [riderId], references: [id])

  @@map("deliveries")
}

model Rider {
  id          String  @id @default(cuid())
  userId      String  @unique
  vehicleType String  @default("motorcycle")
  isOnline    Boolean @default(false)
  isApproved  Boolean @default(false)
  bankAccount String?
  rating      Float   @default(5.0)
  totalRatings Int    @default(0)
  acceptanceRate Float @default(100)
  completionRate Float @default(100)
  onTimeRate   Float  @default(100)

  user      User       @relation(fields: [userId], references: [id])
  deliveries Delivery[]

  @@map("riders")
}

model Rating {
  id         String   @id @default(cuid())
  orderId    String
  raterId    String
  targetId   String
  targetType String   // "restaurant" | "rider"
  score      Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  order  Order @relation(fields: [orderId], references: [id])
  rater  User  @relation("RaterRatings", fields: [raterId], references: [id])
  target User  @relation("TargetRatings", fields: [targetId], references: [id])

  @@map("ratings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  orderId   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ChatMessage {
  id         String   @id @default(cuid())
  orderId    String
  senderId   String
  senderName String
  senderRole String
  message    String   @db.Text
  createdAt  DateTime @default(now())

  order  Order @relation(fields: [orderId], references: [id])
  sender User  @relation(fields: [senderId], references: [id])

  @@map("chat_messages")
}

model RiderEarning {
  id          String    @id @default(cuid())
  riderId     String
  orderId     String    @unique
  baseAmount  Float
  bonusAmount Float     @default(0)
  settledAt   DateTime?
  createdAt   DateTime  @default(now())

  rider User  @relation(fields: [riderId], references: [id])
  order Order @relation(fields: [orderId], references: [id])

  @@map("rider_earnings")
}

model Payout {
  id          String       @id @default(cuid())
  riderId     String
  amount      Float
  status      PayoutStatus @default(pending)
  requestedAt DateTime     @default(now())
  paidAt      DateTime?

  rider User @relation(fields: [riderId], references: [id])

  @@map("payouts")
}

model LoyaltyPoint {
  id        String           @id @default(cuid())
  userId    String
  orderId   String?
  points    Int
  type      LoyaltyPointType
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@map("loyalty_points")
}

model Promotion {
  id           String   @id @default(cuid())
  restaurantId String
  title        String
  description  String?
  type         String   // "percentage" | "flat" | "free_delivery"
  value        Float    @default(0)
  minOrder     Float    @default(0)
  validFrom    DateTime
  validTo      DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("promotions")
}
